# deploy/defaults.env — NON-SECRET config, versioned in git (ADR-016).
# The deploy job concatenates this with the GitHub Actions secrets to render
# deploy/.env on the VPS. NEVER put a secret here (enforced by .githooks/pre-commit).
# Named defaults.env (not .env.defaults) so it doesn't collide with the .env* ignore.

ENVIRONMENT=production
BRAINDAN_DOMAIN=braindan.cc
SESSION_COOKIE_SECURE=true

# Providers — model routing (keys are secrets, injected by CI; ADR-004).
NEBIUS_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct
# `vision` routing-group VLMs (M9, ADR-057 §4): Groq primary, Nebius fallback. Config scalars,
# editable live in Settings -> Models; verified against the live Groq/Nebius catalogs at build.
# Groq decommissioned llama-4-scout-17b (404 in the M9.7 T7 live drill) -> swapped to Groq's
# current free VLM, the Qwen-family qwen3.6-27b (ADR-063).
GROQ_VISION_MODEL=qwen/qwen3.6-27b
NEBIUS_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
# The one `claude` provider serves both models via per-call --model (ADR-045). A model id is the
# raw vendor string; changing one also means updating any *_CHAIN that names it (ADR-045 §3).
CLAUDE_OPUS_MODEL=claude-opus-4-8
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
# Reasoning effort passed to every `claude` CLI call (`--effort`), all routing groups (ADR-045 §5).
# low|medium|high|xhigh|max.
CLAUDE_EFFORT=medium
# STT fallback chain (ADR-020): Groq (whisper-large-v3) primary, OpenAI (whisper-1) fallback.
# GROQ_API_KEY is a secret injected by CI.
STT_CHAIN=groq,openai
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3

# Embeddings — self-hosted nomic via the ollama sidecar (ADR-022). Reached over the internal
# compose network; no API key (localhost). 768-dim; changing model/dim ⇒ migration + reindex.
EMBEDDING_PROVIDER_ID=ollama
OLLAMA_BASE_URL=http://ollama:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# Graph store + planes (ADR-026/031) — the typed-node store; renamed from VAULT_* at M3.
GRAPH_STORE_PATH=/srv/graph-store
# SSH URL of the private PSB-graph repo (ADR-031 §6). The app-level bootstrap wires this as
# the remote and pushes the skeleton on first boot (zero-touch cutover — no VPS git steps).
GRAPH_STORE_REPO=git@github.com:bodyionita/PSB-graph.git
PLANES=Professional,Personal,Family,Friends,Health,Ideas
# Raw capture inputs (audio) — MUST be the persistent bind-mounted volume, not the container's
# ephemeral fs, or un-processed audio is lost on redeploy and can't be retried (rule 2). The
# app default (../data) is dev-only; prod pins it to the /srv/data mount (R2-synced nightly).
DATA_PATH=/srv/data

# MCP + OAuth 2.1 (M5, ADR-046). PUBLIC_BASE_URL is the public origin the OAuth AS advertises in
# its discovery metadata (RFC 8414/9728) and the base of the MCP resource id `<base>/mcp` (RFC 8707)
# — absolute, NO trailing slash. Non-secret, so it lives here. The companion MCP_TOKEN_HMAC_SECRET
# (hashes MCP tokens at rest, like SESSION_SECRET) is a SECRET → GitHub Actions, injected by CI.
PUBLIC_BASE_URL=https://braindan.cc

# Scheduler (ADR-010).
SCHEDULER_TZ=Europe/Bucharest

# Backups — R2 bucket name is config; its creds are secrets injected by CI (ADR-014).
R2_BUCKET=braindan-backups
