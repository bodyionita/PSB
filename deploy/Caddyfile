# Caddy: TLS termination + serves the PWA at / and proxies /api -> FastAPI (03-api.md).
# Cloudflare in front is "Full (strict)". Caddy serves a Cloudflare Origin CA cert via an
# explicit `tls` directive (ADR-017) — NOT automatic ACME, which can't complete behind a
# proxied :443 with :80 firewalled. The cert+key are CI-rendered files (deploy/origin.{crt,key},
# mounted read-only by docker-compose). Replace the domain via BRAINDAN_DOMAIN (deploy/.env).

{$BRAINDAN_DOMAIN:localhost} {
	# Origin TLS: Cloudflare Origin CA cert/key, mounted by the caddy service (ADR-017).
	tls /etc/caddy/origin.crt /etc/caddy/origin.key

	encode zstd gzip

	# API — everything under /api goes to the FastAPI container.
	handle /api/* {
		reverse_proxy api:8000
	}

	# MCP + OAuth 2.1 (M5, ADR-046 / 07-infrastructure.md): the remote MCP server and its
	# OAuth authorization server live on the SAME origin as the API, but at root-level paths
	# (OAuth discovery is spec-fixed at the origin root; the MCP SDK registers `/mcp` exactly).
	# Proxy them to the same api container alongside /api. `/mcp` is matched without a trailing
	# slash so the Streamable-HTTP path resolves exactly (no 307 redirect that breaks connectors).
	# NOTE (manual, un-scriptable): Cloudflare must pass these paths through UN-CACHED — add a
	# Cache Rule bypassing cache for `/mcp*` and `/.well-known/oauth-*` (proxied DNS is fine).
	@mcp_oauth path /mcp /mcp/* /.well-known/oauth-* /authorize /token /register
	handle @mcp_oauth {
		reverse_proxy api:8000
	}

	# PWA static assets + SPA fallback (client-side routing).
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}

	header {
		# Sensible security defaults; refine at provisioning if needed.
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
		# Clickjacking defense-in-depth for the whole origin — the OAuth consent/password page is
		# the design's explicit choke point (ADR-046 §2 security review); nothing here is meant to
		# be framed. SameSite=Lax already forces the password path in a cross-site frame.
		X-Frame-Options DENY
		Content-Security-Policy "frame-ancestors 'none'"
		-Server
	}
}
