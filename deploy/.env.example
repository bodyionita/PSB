# deploy/.env — the file docker compose reads. In production it is RENDERED BY CI, never
# hand-filled and never committed (ADR-016): non-secret config comes from the versioned
# deploy/defaults.env, secret values are injected from the GitHub `production` environment
# secrets. This .env.example only DOCUMENTS the full key set (secret + config) for humans
# and for local dev. NEVER commit a real .env.
#
#   secrets (GitHub Actions): API_PASSWORD_HASH, SESSION_SECRET, DATABASE_URL,
#     OPENAI_API_KEY, NEBIUS_API_KEY, SLACK_USER_TOKEN, R2_ACCOUNT_ID,
#     R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY
#   config (deploy/defaults.env): ENVIRONMENT, BRAINDAN_DOMAIN, SESSION_COOKIE_SECURE,
#     NEBIUS_CHAT_MODEL, CLAUDE_MAX_MODEL, VAULT_PATH, PLANES, SCHEDULER_TZ, R2_BUCKET

# --- Product / TLS ---
ENVIRONMENT=production
BRAINDAN_DOMAIN=braindan.example.com      # the real domain (Cloudflare-proxied)

# --- Auth (ADR-007) ---
API_PASSWORD_HASH=                        # argon2id; scripts/hash_password.py
SESSION_SECRET=                           # long random string
SESSION_COOKIE_SECURE=true

# --- Database: Supabase Postgres + pgvector (ADR-002) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Providers (ADR-004) ---
OPENAI_API_KEY=
NEBIUS_API_KEY=
NEBIUS_CHAT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
CLAUDE_MAX_MODEL=claude-opus-4-8          # real path lit up by `claude login` on the VPS

# --- Vault (ADR-001) ---
VAULT_PATH=/srv/vault
PLANES=Professional,Personal,Family,Friends,Health,Ideas

# --- Connectors (M4) ---
SLACK_USER_TOKEN=

# --- Scheduler (ADR-010). Compose sets ENABLE_SCHEDULER=true for the single api instance. ---
SCHEDULER_TZ=Europe/Bucharest

# GITHUB_DEPLOY_KEY is mounted as a file for vault git push, not an env var.
