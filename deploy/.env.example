# deploy/.env — the file docker compose reads. In production it is RENDERED BY CI, never
# hand-filled and never committed (ADR-016): non-secret config comes from the versioned
# deploy/defaults.env, secret values are injected from the GitHub `production` environment
# secrets. This .env.example only DOCUMENTS the full key set (secret + config) for humans
# and for local dev. NEVER commit a real .env.
#
#   secrets (GitHub Actions): API_PASSWORD_HASH, SESSION_SECRET, DATABASE_URL,
#     OPENAI_API_KEY, NEBIUS_API_KEY, GROQ_API_KEY, SLACK_USER_TOKEN, R2_ACCOUNT_ID,
#     R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY
#   config (deploy/defaults.env): ENVIRONMENT, BRAINDAN_DOMAIN, SESSION_COOKIE_SECURE,
#     NEBIUS_CHAT_MODEL, CLAUDE_OPUS_MODEL, CLAUDE_SONNET_MODEL, CLAUDE_EFFORT, STT_CHAIN, GROQ_BASE_URL,
#     GROQ_STT_MODEL, EMBEDDING_PROVIDER_ID, OLLAMA_BASE_URL, EMBEDDING_MODEL, EMBEDDING_DIM,
#     GRAPH_STORE_PATH, GRAPH_STORE_REPO, DATA_PATH, PLANES, SCHEDULER_TZ, R2_BUCKET
#
# Origin TLS (ADR-017) is delivered as FILES, not .env keys: the GitHub secrets
# ORIGIN_CERT_PEM / ORIGIN_KEY_PEM (Cloudflare Origin CA cert + key, multi-line PEM) are
# rendered by CI to deploy/origin.crt / deploy/origin.key (mode 600) and mounted into Caddy.

# --- Product / TLS ---
ENVIRONMENT=production
BRAINDAN_DOMAIN=braindan.example.com      # the real domain (Cloudflare-proxied)

# --- Auth (ADR-007) ---
API_PASSWORD_HASH=                        # argon2id; scripts/hash_password.py
SESSION_SECRET=                           # long random string
SESSION_COOKIE_SECURE=true

# --- Database: Supabase Postgres + pgvector (ADR-002) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Providers (ADR-004) ---
OPENAI_API_KEY=                           # STT fallback (whisper-1) only — embeddings moved to Ollama
NEBIUS_API_KEY=
NEBIUS_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct
CLAUDE_OPUS_MODEL=claude-opus-4-8         # one `claude` provider serves both (ADR-045); lit up by `claude login`
CLAUDE_SONNET_MODEL=claude-sonnet-4-6     # the cheaper model, routed to the `quick` group
CLAUDE_EFFORT=medium                      # --effort on every `claude` call, all groups (ADR-045 §5)
# STT fallback chain (ADR-020): Groq (whisper-large-v3) primary, OpenAI (whisper-1) fallback.
GROQ_API_KEY=                             # STT primary
STT_CHAIN=groq,openai
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3
# Embeddings — self-hosted nomic via the ollama sidecar (ADR-022). Keyless (localhost), 768-dim.
EMBEDDING_PROVIDER_ID=ollama
OLLAMA_BASE_URL=http://ollama:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --- Graph store (ADR-026/031) — typed-node store; renamed from VAULT_* at M3 ---
GRAPH_STORE_PATH=/srv/graph-store
GRAPH_STORE_REPO=git@github.com:bodyionita/PSB-graph.git  # app wires this remote + push -u (ADR-031 §6)
DATA_PATH=/srv/data                       # persistent bind mount; audio survives redeploys (rule 2)
PLANES=Professional,Personal,Family,Friends,Health,Ideas

# --- Connectors (M9 post-pivot roadmap) ---
SLACK_USER_TOKEN=

# --- Scheduler (ADR-010). Compose sets ENABLE_SCHEDULER=true for the single api instance. ---
SCHEDULER_TZ=Europe/Bucharest

# Graph-store git push (ADR-014) uses SSH, not an env var: the deploy key generated by provision.sh
# at /home/deploy/.ssh/graph_store_deploy_key is bind-mounted read-only into the api container
# (docker-compose.yml); the entrypoint installs it root-owned 0600 + pins GitHub's host key.
