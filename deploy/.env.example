# deploy/.env — production secrets for docker compose. NEVER commit the real .env.
# All keys the VPS needs (07-infrastructure.md secrets list). Dormant until provisioning.

# --- Product / TLS ---
ENVIRONMENT=production
BRAINDAN_DOMAIN=braindan.example.com      # the real domain (Cloudflare-proxied)

# --- Auth (ADR-007) ---
API_PASSWORD_HASH=                        # argon2id; scripts/hash_password.py
SESSION_SECRET=                           # long random string
SESSION_COOKIE_SECURE=true

# --- Database: Supabase Postgres + pgvector (ADR-002) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Providers (ADR-004) ---
OPENAI_API_KEY=
NEBIUS_API_KEY=
NEBIUS_CHAT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
CLAUDE_MAX_MODEL=claude-opus-4-8          # real path lit up by `claude login` on the VPS

# --- Vault (ADR-001) ---
VAULT_PATH=/srv/vault
PLANES=Professional,Personal,Family,Friends,Health,Ideas

# --- Connectors (M4) ---
SLACK_USER_TOKEN=

# --- Scheduler (ADR-010). Compose sets ENABLE_SCHEDULER=true for the single api instance. ---
SCHEDULER_TZ=Europe/Bucharest

# GITHUB_DEPLOY_KEY is mounted as a file for vault git push, not an env var.
