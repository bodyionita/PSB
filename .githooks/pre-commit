#!/bin/sh
# Braindan pre-commit guard. Two responsibilities, both enforced before every commit:
#
#   1) SECRET GUARD (never bypass) — private keys, credential files, or secret-shaped
#      values must NEVER be committed (09-session-protocol.md, "Security & secrets
#      discipline"). Bypassing this with `git commit --no-verify` is forbidden for secret
#      material; a committed secret is the single worst outcome — rotate it immediately.
#
#   2) LINT + FORMAT GATE (CLAUDE.md rule 10 / "CI must stay green per directory") — the
#      exact linters CI runs, applied to the STAGED files, so a lint/format error can never
#      reach `main` and break the deploy again. Python (server): `ruff check` + `ruff format
#      --check`. Web: `eslint --max-warnings 0` (the web has no separate formatter; eslint is
#      the format authority). Scoped to staged files so pre-existing drift elsewhere never
#      blocks an unrelated commit, and a server-only commit never pays for the web toolchain.
#
# Zero secret-guard dependencies (POSIX sh + git). The lint gate needs `uv` (server) and
# `pnpm` (web) on PATH only when files in that subtree are staged; if the tool is missing it
# fails closed with a clear message rather than skipping the check. Wired via:
#   git config core.hooksPath .githooks

fail=0
red()  { printf '\033[31m%s\033[0m\n' "$1" >&2; }
yell() { printf '\033[33m%s\033[0m\n' "$1" >&2; }

staged=$(git diff --cached --name-only --diff-filter=ACM)

# ---------------------------------------------------------------------------
# 1) SECRET GUARD
# ---------------------------------------------------------------------------

# 1a) Filename block — credential / key material that must never be tracked.
for f in $staged; do
  base=${f##*/}
  case "$base" in
    *.pub) : ;;                                   # public keys are safe
    .env|.env.*)
      case "$base" in
        *.example|*.sample|*.template) : ;;       # placeholders are fine
        *) red "BLOCKED (secret file): $f"; fail=1 ;;
      esac ;;
    id_rsa|id_dsa|id_ecdsa|id_ed25519|id_rsa.*|id_ed25519.*|id_ecdsa.*|id_dsa.* \
    |*.pem|*.key|*.crt|*.p12|*.pfx|*.jks|*.keystore|*_rsa|*_ed25519)
      red "BLOCKED (key/cert material): $f"; fail=1 ;;
  esac
done

# Added lines in the staged diff (strip the +++ file-header lines).
added=$(git diff --cached -U0 --no-color | grep -E '^\+' | grep -Ev '^\+\+\+')

# 1b) Secret-shaped values — high signal, low false-positive.
patterns='-----BEGIN[A-Z ]*PRIVATE KEY-----|AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9_-]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|gh[pousr]_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{50,}|sbp_[A-Za-z0-9]{40,}'
hits=$(printf '%s\n' "$added" | grep -En -- "$patterns")
if [ -n "$hits" ]; then
  red "BLOCKED (secret-shaped value in staged changes):"
  printf '%s\n' "$hits" >&2
  fail=1
fi

# 1c) Database URL with a real host + inline password (localhost/UPPER placeholders allowed).
dburl=$(printf '%s\n' "$added" \
  | grep -E 'postgres(ql)?://[^:@ ]+:[^@ ]+@[^/ ]*\.[^/ ]+' \
  | grep -Eiv ':(password|changeme|your[-_]?password|xxx+)@')
if [ -n "$dburl" ]; then
  red "BLOCKED (database URL with inline password):"
  printf '%s\n' "$dburl" >&2
  fail=1
fi

# 1d) PII guard — real contacts' FULL names (first + last) must never enter these public repos
# (ADR-064 redaction; the graph's real people are referred to by placeholder/first-name only). Only
# full-name combos are blocked — lone first or last names are fine (a bare surname like "Soare" also
# means "sun"). Fabricated illustrative names (Diana Vance, Horia Fenwick, …) are the intended
# stand-ins. The denylist is stored as SHA-256 of the diacritic-folded, lower-cased name, so the real
# names themselves NEVER appear in this public repo (a plaintext denylist would re-leak them).
if command -v python >/dev/null 2>&1; then _py=python
elif command -v python3 >/dev/null 2>&1; then _py=python3
else _py=; fi
if [ -n "$_py" ]; then
  # Pipe the staged additions to the hashed scanner (.githooks/pii_scan.py holds only SHA-256
  # digests, never the names). Exclude the hook dir itself from the scan.
  names=$(git diff --cached -U0 --no-color -- . ':!.githooks/' \
    | grep -E '^\+' | grep -Ev '^\+\+\+' | "$_py" .githooks/pii_scan.py)
  if [ -n "$names" ]; then
    red "BLOCKED (real contact full name in staged changes — use a placeholder/first-name only):"
    printf '%s\n' "$names" >&2
    fail=1
  fi
else
  yell "PII name-guard skipped: no python on PATH (history is already redacted; install python to re-enable)."
fi

if [ "$fail" -ne 0 ]; then
  red ""
  red "Commit refused: credentials + real personal names must never enter git"
  red "(09-session-protocol.md security discipline; ADR-064 PII redaction)."
  red "Real secrets belong only in deploy/.env on the VPS (gitignored), the process"
  red "environment, or GitHub Actions secrets — never in a tracked file."
fi

# ---------------------------------------------------------------------------
# 2) LINT + FORMAT GATE (mirrors CI, scoped to staged files)
# ---------------------------------------------------------------------------

# Staged Python files under server/ (paths relative to server/ for ruff's config discovery).
py_files=$(printf '%s\n' "$staged" | sed -n 's#^server/##p' | grep -E '\.py$')
if [ -n "$py_files" ]; then
  if ! command -v uv >/dev/null 2>&1; then
    red "BLOCKED (lint): staged server/*.py but 'uv' is not on PATH — install uv to commit."
    fail=1
  else
    if ! ( cd server && uv run ruff check -- $py_files ) >&2; then
      red "BLOCKED (ruff check): fix the lint errors above, then re-stage and commit."
      fail=1
    fi
    if ! ( cd server && uv run ruff format --check -- $py_files ) >&2; then
      red "BLOCKED (ruff format): run 'cd server && uv run ruff format <files>', re-stage, commit."
      fail=1
    fi
  fi
fi

# Staged web source files (js/ts family — eslint's scope; run from web/ with relative paths).
web_files=$(printf '%s\n' "$staged" | sed -n 's#^web/##p' | grep -E '\.(ts|tsx|js|jsx|cjs|mjs)$')
if [ -n "$web_files" ]; then
  if ! command -v pnpm >/dev/null 2>&1; then
    red "BLOCKED (lint): staged web/* source but 'pnpm' is not on PATH — install pnpm to commit."
    fail=1
  else
    if ! ( cd web && pnpm exec eslint --max-warnings 0 -- $web_files ) >&2; then
      red "BLOCKED (eslint): fix the lint/format errors above, then re-stage and commit."
      fail=1
    fi
  fi
fi

if [ "$fail" -ne 0 ]; then
  yell ""
  yell "Pre-commit checks failed. Nothing was committed. (--no-verify bypasses this, but is"
  yell "forbidden for secrets and defeats the lint gate that keeps CI/deploy green.)"
  exit 1
fi

exit 0
