# Braindan server — environment. Copy to .env for local dev. NEVER commit .env.
# Every key the service reads is documented here (07-infrastructure.md secrets list).

# --- Product / environment ---
ENVIRONMENT=development            # development | production

# --- Auth (ADR-007) ---
# Argon2id hash of the login password. Generate: python scripts/hash_password.py 'pw'
API_PASSWORD_HASH=
# Secret used to hash session tokens before storage. Set a long random value.
SESSION_SECRET=dev-insecure-change-me
SESSION_COOKIE_SECURE=false        # true behind Cloudflare/Caddy TLS in production
SESSION_TTL_DAYS=30

# --- Database (ADR-002). Local dev value matches docker-compose.dev.yml. ---
DATABASE_URL=postgresql://braindan:braindan@localhost:5432/braindan

# --- Graph store (M3 pivot, ADR-026/030/031). Prod = /srv/graph-store (07-infra). ---
GRAPH_STORE_PATH=../graph-store
# SSH URL of the private PSB-graph repo; empty ⇒ bootstrap skips the remote (dev).
# Prod value lands via deploy/defaults.env (ADR-031 zero-touch cutover).
GRAPH_STORE_REPO=
# Seeded vocabulary (ADR-031): 9 node types / 6 edge rels; growth is governed (ADR-027).
# NODE_TYPES=memory,person,idea,conversation,insight,place,event,project,topic
# EDGE_RELS=involves,about,part_of,led_to,follows,at
# Types carrying aliases/disambig/derived profiles (ADR-030); subset of NODE_TYPES.
# ENTITY_LIKE_TYPES=person,place,topic,idea,event,project
# Entity-resolution confidence floor (ADR-030; live-tuned at the M3 Accept): below it the
# organizer files an entity-ambiguity review item instead of linking.
ENTITY_MATCH_MIN_CONF=0.8
# MCP capture burst queue (ADR-031): beyond N in-flight organizes, MCP captures wait.
MCP_CAPTURE_MAX_INFLIGHT=2
# Nightly derived-profile refresh for touched entities (ADR-030/032), after the reindex.
# PROFILE_REFRESH_CRON=10 4 * * *

# --- Planes (ADR-005 surviving half — frontmatter attributes, not folders) ---
PLANES=Professional,Personal,Family,Friends,Health,Ideas

# --- Graph-store backup / durability (ADR-014; ex-VAULT_*, renamed at M3) ---
# The server only ever fast-forward pushes here; never force/rebase/reset. Remote URL comes from
# GRAPH_STORE_REPO via the app bootstrap (ADR-031). Dev usually has no remote → commits stay local.
STORE_GIT_REMOTE=origin
STORE_GIT_BRANCH=main
# Writes are coalesced into one commit per debounce window (~60s batch commits).
STORE_BACKUP_DEBOUNCE_SECONDS=60
# Commit identity written into the repo config.
GIT_USER_NAME=Braindan
GIT_USER_EMAIL=braindan@braindan.local

# --- Capture pipeline (M1, ADR-019) ---
# Raw audio is saved here as {capture_id}.{ext} before any model call. Prod = /srv/data.
DATA_PATH=../data
# System FOLDER for the organizer's "can't classify" + failure fallback (02 §1, ADR-026).
INBOX_FOLDER=inbox
# Whisper hard limit; larger uploads are rejected before persistence.
AUDIO_MAX_BYTES=26214400
# Bounds enforced on a single organize result.
ORGANIZER_MAX_NODES=8
ORGANIZER_MAX_TAGS=12

# --- Provider registry (ADR-004) ---
# OpenAI: STT fallback (whisper-1) only — embeddings moved to self-hosted Ollama (ADR-022).
OPENAI_API_KEY=
# Nebius: OpenAI-compatible chat fallback.
NEBIUS_API_KEY=
NEBIUS_CHAT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# claude-max is health-guarded: with no local CLI/login it falls back to Nebius (ADR-012).
CLAUDE_MAX_MODEL=claude-opus-4-8
# Reasoning effort on every claude-max CLI call (M1 replan). low|medium|high|xhigh|max.
CLAUDE_MAX_EFFORT=medium
# STT fallback chain (ADR-020): Groq (whisper-large-v3) primary, OpenAI (whisper-1) fallback.
# Empty GROQ_API_KEY ⇒ Groq is unavailable and the chain falls straight to OpenAI.
GROQ_API_KEY=
# STT_CHAIN=groq,openai
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_STT_MODEL=whisper-large-v3

# --- Embeddings: self-hosted nomic via Ollama (ADR-022). Single provider, 768-dim. ---
# Local dev: `ollama serve` + `ollama pull nomic-embed-text`; or leave it — the index step
# fails retryably without it and the next rescan converges. Prod points at the ollama sidecar
# (deploy/defaults.env → http://ollama:11434/v1). No API key (localhost). Changing the model or
# dim means a migration + full reindex.
# EMBEDDING_PROVIDER_ID=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768

# --- Object storage / R2 backups (ADR-014). Empty ⇒ backups disabled (dev); jobs skip. ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=braindan-backups
# Optional endpoint override; default derives https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=

# --- Connectors (M9 post-pivot roadmap) ---
SLACK_USER_TOKEN=

# --- Scheduler (ADR-010). Off locally; exactly one instance sets true in prod. ---
ENABLE_SCHEDULER=false
# SCHEDULER_TZ=Europe/Bucharest
# SCHEDULER_MISFIRE_GRACE_SECONDS=3600
# Durability job schedule (standard 5-field crontab, evaluated in SCHEDULER_TZ).
# BACKUP_DATA_SYNC_CRON=10 3 * * *
# BACKUP_DB_BACKUP_CRON=25 3 * * *
# INTEGRITY_DRILL_CRON=30 4 * * sun
# BACKUP_STORE_SWEEP_CRON=55 4 * * *
# BACKUP_STORE_BUNDLE_CRON=57 4 * * *
# INTEGRITY_DRILL_MAX_AGE_DAYS=8

# --- Web / CORS (dev only) ---
CORS_ORIGINS=http://localhost:5173
