# Braindan server — environment. Copy to .env for local dev. NEVER commit .env.
# Every key the service reads is documented here (07-infrastructure.md secrets list).

# --- Product / environment ---
ENVIRONMENT=development            # development | production

# --- Auth (ADR-007) ---
# Argon2id hash of the login password. Generate: python scripts/hash_password.py 'pw'
API_PASSWORD_HASH=
# Secret used to hash session tokens before storage. Set a long random value.
SESSION_SECRET=dev-insecure-change-me
SESSION_COOKIE_SECURE=false        # true behind Cloudflare/Caddy TLS in production
SESSION_TTL_DAYS=30

# --- Database (ADR-002). Local dev value matches docker-compose.dev.yml. ---
DATABASE_URL=postgresql://braindan:braindan@localhost:5432/braindan

# --- Vault (ADR-001) ---
VAULT_PATH=../ObisidanVault
PLANES=Professional,Personal,Family,Friends,Health,Ideas

# --- Provider registry (ADR-004) ---
# OpenAI: embeddings (text-embedding-3-small) + Whisper STT. Fixed models.
OPENAI_API_KEY=
# Nebius: OpenAI-compatible chat fallback.
NEBIUS_API_KEY=
NEBIUS_CHAT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# claude-max is health-guarded: with no local CLI/login it falls back to Nebius (ADR-012).
CLAUDE_MAX_MODEL=claude-opus-4-8

# --- Connectors (M4) ---
SLACK_USER_TOKEN=

# --- Scheduler (ADR-010). Off locally; exactly one instance sets true in prod. ---
ENABLE_SCHEDULER=false

# --- Web / CORS (dev only) ---
CORS_ORIGINS=http://localhost:5173
